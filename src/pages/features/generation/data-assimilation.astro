---
import Content from '~/components/widgets/Content.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Data Assimilation',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Generation"
    title="Data Assimilation"
    subtitle="Integrate real-world observations with generative models to produce synthetic data that faithfully reflects source distributions."
  />

  <Content
    items={[
      {
        title: 'Multi-Source Fusion',
        description: 'Combine data from heterogeneous sources while resolving schema conflicts and maintaining referential integrity.',
        icon: 'tabler:layers-intersect',
      },
      {
        title: 'Distribution Alignment',
        description: 'Align marginal and joint distributions so that synthetic outputs match observed statistics across all dimensions.',
        icon: 'tabler:chart-dots',
      },
      {
        title: 'Incremental Updates',
        description: 'Assimilate new data incrementally without retraining from scratch, keeping models current as observations evolve.',
        icon: 'tabler:refresh',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1558494949-ef010cbdcc31?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Data Assimilation',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Grounded in Reality</h3>
    </Fragment>
  </Content>
</Layout>