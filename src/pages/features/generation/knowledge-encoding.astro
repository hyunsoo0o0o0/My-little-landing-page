---
import Content from '~/components/widgets/Content.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Knowledge Encoding',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Generation"
    title="Knowledge Encoding"
    subtitle="Transform domain expertise into structured representations that guide synthetic data generation with precision and fidelity."
  />

  <Content
    items={[
      {
        title: 'Domain Knowledge Capture',
        description: 'Encode expert understanding of data distributions, constraints, and relationships into machine-readable formats.',
        icon: 'tabler:brain',
      },
      {
        title: 'Schema-Aware Encoding',
        description: 'Preserve data types, ranges, and inter-column dependencies so that generated data respects the original schema.',
        icon: 'tabler:code',
      },
      {
        title: 'Rule Integration',
        description: 'Inject business rules and validation logic directly into the generation pipeline to ensure compliance from the start.',
        icon: 'tabler:list-check',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1456513080510-7bf3198fc652?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Knowledge Encoding',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">From Expertise to Data</h3>
    </Fragment>
  </Content>
</Layout>