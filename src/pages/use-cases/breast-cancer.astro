---
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Breast Cancer',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Use Cases"
    title="Breast Cancer"
    subtitle="Accelerate oncology research with synthetic clinical and imaging data that preserves diagnostic signal while protecting patient confidentiality."
  />

  <Content
    items={[
      {
        title: 'Synthetic Mammography',
        description: 'Generate realistic mammographic images for CAD system training without accessing sensitive patient records.',
        icon: 'tabler:scan',
      },
      {
        title: 'Clinical Trial Simulation',
        description: 'Simulate patient cohorts with diverse demographics and tumor profiles to support treatment outcome studies.',
        icon: 'tabler:flask',
      },
      {
        title: 'Rare Subtype Augmentation',
        description: 'Enlarge limited datasets of rare breast cancer subtypes to improve early-detection model accuracy.',
        icon: 'tabler:stethoscope',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1576091160550-2173dba999ef?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Breast Cancer Research',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Fighting Cancer with Data</h3>
    </Fragment>
  </Content>
</Layout>