---
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

const metadata = {
  title: 'Environment',
};
---

<Layout metadata={metadata}>
  <Hero
    tagline="Use Cases"
    title="Environment"
    subtitle="Simulate environmental data to model climate scenarios, pollution patterns, and ecological dynamics at scale."
  />

  <Content
    items={[
      {
        title: 'Climate Scenario Modeling',
        description: 'Generate synthetic climate data under different emission pathways to stress-test infrastructure and policy plans.',
        icon: 'tabler:cloud-storm',
      },
      {
        title: 'Pollution Forecasting',
        description: 'Augment sparse sensor data with synthetic readings to improve air and water quality prediction models.',
        icon: 'tabler:wind',
      },
      {
        title: 'Ecological Simulation',
        description: 'Simulate biodiversity and habitat data to study species interactions and conservation outcomes.',
        icon: 'tabler:trees',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Environment',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Sustainability at Scale</h3>
    </Fragment>
  </Content>
</Layout>