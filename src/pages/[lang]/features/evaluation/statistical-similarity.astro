---
import type { GetStaticPaths } from 'astro';
import { locales, type Locale } from '~/i18n';
import Content from '~/components/widgets/Content.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'Statistical Similarity',
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="Evaluation"
    title="Statistical Similarity"
    subtitle="Measure how closely synthetic data matches the statistical properties of the original dataset."
  />

  <Content
    items={[
      {
        title: 'Marginal Distribution Fidelity',
        description: 'Compare column-wise distributions using KS tests, Wasserstein distance, and percentile alignment.',
        icon: 'tabler:chart-histogram',
      },
      {
        title: 'Joint Distribution Integrity',
        description: 'Evaluate multivariate relationships and correlation structures to ensure dependencies are preserved.',
        icon: 'tabler:chart-dots-3',
      },
      {
        title: 'Summary Statistic Parity',
        description: 'Verify that key descriptive statistics — means, variances, skewness — align between real and synthetic data.',
        icon: 'tabler:math-function',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1551288049-bebba4e2a583?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Statistical Similarity',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Measuring Fidelity</h3>
    </Fragment>
  </Content>
</Layout>