---
import type { GetStaticPaths } from 'astro';
import { getRelativeLocaleUrl } from 'astro:i18n';
import { locales, type Locale } from '~/i18n';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'Features',
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="Features"
    title="SSTDV Generation & Evaluation"
    subtitle="Explore the core capabilities that power synthetic data generation and evaluation across diverse domains."
  />

  <Features2
    title="Core Capabilities"
    subtitle="SSTDV provides two pillars of functionality: data generation and evaluation."
    columns={2}
    items={[
      {
        title: 'Generation',
        description: 'Produce high-fidelity synthetic tabular data through knowledge encoding, relation modeling, data assimilation, and objective-reinforced learning.',
        icon: 'tabler:database',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/features/generation/') },
      },
      {
        title: 'Evaluation',
        description: 'Assess synthetic data quality with statistical similarity, objective relevance, and Turing-test-based metrics.',
        icon: 'tabler:chart-bar',
        callToAction: { text: 'Learn more', href: getRelativeLocaleUrl(lang, '/features/evaluation/') },
      },
    ]}
  />
</Layout>