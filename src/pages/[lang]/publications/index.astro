---
import type { GetStaticPaths } from 'astro';
import { locales, type Locale } from '~/i18n';
import Content from '~/components/widgets/Content.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'Publications',
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="Publications"
    title="Research & Patents"
    subtitle="Explore our published papers and patents advancing the state of synthetic data generation and evaluation."
  />

  <Content
    title="Selected Publications"
    subtitle="Our peer-reviewed research contributions to synthetic spatio-temporal data generation and evaluation."
    columns={1}
    items={[
      {
        title: 'Privacy-Preserving Synthetic Medical Imaging Data Generation using Diffeomorphic Flows',
        description: '권도현, 이서연, 박지훈, 최영민 | Nature Machine Intelligence, 2025',
      },
      {
        title: 'Temporal Consistency in Synthetic Spatio-Temporal Data: A Benchmark Study',
        description: '김태형, 정수민, 한동희 | ICML, 2025',
      },
      {
        title: 'Cross-Domain Adaptation of Synthetic Data Generators for Environmental Monitoring',
        description: '이준호, 최민지, 강성호 | AAAI, 2025',
      },
      {
        title: 'Uncertainty Quantification in Synthetic Medical Time Series: A Bayesian Approach',
        description: '박서린, 김동윤, 조민수 | ICLR, 2024',
      },
      {
        title: 'Evaluation Metrics for Synthetic Spatio-Temporal Data: A Comprehensive Survey',
        description: '정하은, 윤석호, 허성현 | TPAMI, 2024',
      },
    ]}
  />

  <Content
    title="Preprints & Technical Reports"
    subtitle="Our ongoing research and technical contributions available as preprints."
    columns={1}
    items={[
      {
        title: 'Synthetic Data Generation for Rare Disease Imaging: A Feasibility Study',
        description: '최수진, 김현우, 박종석 | arXiv, 2026',
      },
      {
        title: 'Federated Learning with Synthetic Data: Privacy and Utility Trade-offs',
        description: '서예린, 이동훈, 김지수 | Technical Report, 2026',
      },
    ]}
  />
</Layout>
