---
import type { GetStaticPaths } from 'astro';
import { locales, type Locale } from '~/i18n';
import Content from '~/components/widgets/Content.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Hero from '~/components/widgets/Hero.astro';
import Layout from '~/layouts/PageLayout.astro';

export const getStaticPaths: GetStaticPaths = async () => {
  return locales.map((locale) => ({ params: { lang: locale } }));
};

const { lang } = Astro.params as { lang: Locale };

const metadata = {
  title: 'Brain Imaging',
};
---

<Layout metadata={metadata} lang={lang}>
  <Hero
    tagline="Use Cases"
    title="Brain Imaging"
    subtitle="Generate synthetic neuroimaging data to accelerate research while preserving patient privacy and diagnostic fidelity."
  />

  <Content
    items={[
      {
        title: 'Privacy-Preserving MRI Synthesis',
        description: 'Produce realistic brain MRI volumes without exposing patient identifiers, enabling multi-site collaboration.',
        icon: 'tabler:brain',
      },
      {
        title: 'Rare Condition Augmentation',
        description: 'Augment underrepresented neurological conditions to balance datasets for robust model training.',
        icon: 'tabler:zoom-scan',
      },
      {
        title: 'Cross-Scanner Harmonization',
        description: 'Simulate data across different scanner protocols and field strengths to improve model generalization.',
        icon: 'tabler:adjustments',
      },
    ]}
    image={{
      src: 'https://images.unsplash.com/photo-1559757175-5700dde675bc?ixlib=rb-4.0.3&auto=format&fit=crop&w=1740&q=80',
      alt: 'Brain Imaging',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Advancing Neuroscience</h3>
    </Fragment>
  </Content>
</Layout>